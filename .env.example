# ============================================================================
# FITBOX environment variables
#
# The current app is a frontend static export with MOCK data and does NOT require
# any of these to run locally. They document the production target described in the
# design docs (Supabase + Razorpay/Stripe + Resend + a Node/Express Studio API).
# Copy to .env.local and fill in when wiring real services.
# ============================================================================

# Supabase (DB + Auth + Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (primary — INR: UPI / cards / net banking / wallets)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (international cards — USD)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@fitbox.in

# Studio API (Node/Express on Railway — AI design generation + preview rendering)
STUDIO_API_URL=
STUDIO_API_KEY=
AI_IMAGE_PROVIDER_KEY=

# App config
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=149900   # paise (₹1499)
NEXT_PUBLIC_SITE_URL=https://fitbox.in
